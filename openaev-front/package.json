    "@stylistic/eslint-plugin": "5.10.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/d3-hierarchy": "3.1.7",
    "@types/node": "22.19.18",
    "@types/pdfmake": "0.3.2",
    "@types/qs": "6",
