    "license-checker-rseidelsohn": "4.4.2",
    "monocart-coverage-reports": "2.12.11",
    "monocart-reporter": "2.11.2",
    "swagger-typescript-api": "13.9.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  },
  "resolutions": {
    "@types/react": "19.2.14",
    "form-data": "4.0.5",
    "html-to-image": "patch:html-to-image@1.11.13#./patches/html-to-image.patch",
