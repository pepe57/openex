    "@typescript-eslint/utils": "8.59.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/eslint-plugin": "1.6.17",
    "chokidar": "5.0.0",
    "cross-env": "10.1.0",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "eslint-plugin-custom-rules": "workspace:*",
